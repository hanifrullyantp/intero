# Salin ke .env di root proyek (jangan commit .env)

# --- Supabase (opsional): jika keduanya diset, frontend pakai Supabase, bukan API lokal ---
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Admin login (hanya untuk mode Express lokal / Docker, BUKAN Supabase Auth)
ADMIN_USERNAME=admin
# Gunakan salah satu: password plain (dev) ATAU hash bcrypt (prod)
ADMIN_PASSWORD=ganti-password-ini
# ADMIN_PASSWORD_HASH=$2a$10$...

# JWT — wajib panjang di production (set NODE_ENV=production)
JWT_SECRET=minimal-16-karakter-rahasia

# Server
PORT=8787

# Di balik Nginx/Caddy dengan HTTPS — wajib untuk cookie admin Secure
# TRUST_PROXY=1

# Opsional: notifikasi lead
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# ADMIN_NOTIFY_EMAIL=
